// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "cli_default_open_behavior": "existing_window",
  "project_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "agent": {
    "default_profile": "write",
    "default_model": {
      "provider": "x_ai",
      "model": "grok-4-1-fast-non-reasoning",
      "enable_thinking": false
    },
    "dock": "right",
    "favorite_models": [],
    "model_parameters": []
  },
  "git_panel": {
    "dock": "left"
  },
  "helix_mode": false,
  "terminal": {
    "font_family": "JetBrainsMono Nerd Font",
    "shell": "system",
    "env": { "LD_LIBRARY_PATH": "" },
  },
  "agent_servers": {
    "github-copilot-cli": {
      "type": "registry"
    }
  },
  "remove_trailing_whitespace_on_save": false,
  "edit_predictions": {
    "mode": "subtle",
    "provider": "none",
  },
  "lsp_document_colors": "background",
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "check": {
          "command": "clippy"
        },
        "rust": {
          "analyzerTargetDir": true,
        },
      },
    },
  },
  "message_editor": {
    "auto_replace_emoji_shortcode": false,
  },
  "tabs": {
    "file_icons": true,
  },
  "auto_update_extensions": {
    "crates-lsp": false,
  },
  "prettier": {
    "allowed": true,
  },
  "icon_theme": {
    "mode": "dark",
    "light": "JetBrains New UI Icons (Light)",
    "dark": "JetBrains New UI Icons (Dark)",
  },
  "agent_ui_font_size": 13.0,
  "ui_font_weight": 300.0,
  "ui_font_family": "JetBrainsMono Nerd Font",
  "format_on_save": "off",
  "show_whitespaces": "all",
  "inlay_hints": {
    "show_background": true,
    "enabled": true,
  },
  "languages": {
    "RON": {
      "format_on_save": "on",
      "remove_trailing_whitespace_on_save": true,
      "preferred_line_length": 100,
      "language_servers": ["ron-lsp"],
      "enable_language_server": true,
      "formatter": "language_server",
    },
    "C++": {
      "tab_size": 8,
    },
    "C": {
      "hard_tabs": true,
      "tab_size": 8,
    },
    "Markdown": {
      "tab_size": 4,
    },
    "Markdown-Inline": {
      "tab_size": 4,
    },
    "Python": {
      "language_servers": ["ty", "ruff", "!basedpyright"],
      "preferred_line_length": 100,
    },
    "Rust": {
      "colorize_brackets": true,
      "formatter": "language_server",
      "ensure_final_newline_on_save": false,
      "remove_trailing_whitespace_on_save": true,
      "inlay_hints": {
        "show_background": true,
        "enabled": true,
      },
    },
  },
  "diagnostics_max_severity": "warning",
  "diagnostics": {
    "inline": {
      "enabled": true,
    },
  },
  "ssh_connections": [
    {
      "host": "build4",
      "args": [],
      "projects": [
        {
          "paths": ["/home/trungdt/image-recipes"],
        },
      ],
    },
  ],
  "disable_ai": false,
  "auto_update": false,
  "outline_panel": {
    "dock": "right",
  },
  "base_keymap": "JetBrains",
  "telemetry": {
    "metrics": false,
    "diagnostics": false,
  },
  "ui_font_size": 14.0,
  "buffer_font_size": 12.0,
  "buffer_font_family": "JetBrainsMonoNL Nerd Font Mono",
  "buffer_font_weight": 100.0,
  "buffer_line_height": "standard",
  "theme": "Gruvbox Crisp Anysphere Blend Dark",
  "proxy": "http://10.116.43.167:8082",
}
